# PRAGATI.AI Environment Variables
# Copy this file, rename to .env, and fill in your real keys
# The .env file is NEVER uploaded to GitHub

GROQ_API_KEY=your_groq_api_key_here
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
ETHEREUM_PRIVATE_KEY=your_64_char_private_key_no_0x
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here